# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will never be committed.

# ==================== LLM 提供方 ====================

# Flowcut LLM provider：gemini 或 volcengine。
# 留空时如果存在 GOOGLE_API_KEY，会优先使用 gemini；否则回退到 volcengine。
FLOWCUT_LLM_PROVIDER=gemini

# --- Google Gemini（FLOWCUT_LLM_PROVIDER=gemini 时使用）---
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-3.1-flash-lite
FLOWCUT_HOOK_MODEL=gemini-3.1-flash-lite
FLOWCUT_FIRST_TOKEN_MODEL=gemini-3.1-flash-lite
FLOWCUT_FIRST_TOKEN_ENABLED=true
FLOWCUT_FIRST_TOKEN_TIMEOUT_MS=2500
FLOWCUT_FIRST_TOKEN_MAX_TOKENS=48
FLOWCUT_FIRST_TOKEN_TEMPERATURE=0.6

# --- Volcengine / Doubao（Mojing + Flowcut 可共用）---
VOLCENGINE_API_KEY=
VOLCENGINE_API_BASE=
VOLCENGINE_MODEL=doubao-seed-2-0-lite-260215
VOLCENGINE_HOOK_MODEL=doubao-seed-2-0-lite-260215
VOLCENGINE_FIRST_TOKEN_MODEL=doubao-seed-2-0-lite-260215
VOLCENGINE_FIRST_TOKEN_API_KEY=
FIRST_TOKEN_LLM_ENABLED=true
FIRST_TOKEN_TIMEOUT_MS=2500
FIRST_TOKEN_MAX_TOKENS=48
FIRST_TOKEN_TEMPERATURE=0.6

# ==================== 数据库 ====================

# MySQL（Mojing 和 Flowcut 共用）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DB=simpleclaw
MYSQL_POOL_MIN=2
MYSQL_POOL_MAX=30

# Redis（可选，留空则使用内存队列）
REDIS_URL=

# ==================== OSS 对象存储（Flowcut 素材/成片）====================

FLOWCUT_OSS_ENDPOINT=
FLOWCUT_OSS_ACCESS_KEY_ID=
FLOWCUT_OSS_ACCESS_KEY_SECRET=
FLOWCUT_OSS_BUCKET=

# ==================== 语音识别（Flowcut ASR — 字节跳动 BigModel）====================

# 字节跳动 BigModel 语音识别应用 Key
FLOWCUT_ASR_APP_KEY=
# 字节跳动 BigModel 语音识别访问 Key
FLOWCUT_ASR_ACCESS_KEY=

# ==================== Mojing 特定 ====================

# Skin diary crop service
SKIN_DIARY_CROP_ENDPOINT_URL=
SKIN_DIARY_CROP_TIMEOUT_S=20

# 图片分析 / 深度报告 URL
# MOJING_IMAGE_ANALYSIS_URL=
# MOJING_DEEP_RESEARCH_URL=

# Mojing backend device hooks
DEVICE_DISMISS_API_URL=https://test.onrunlab.com/mojing/app-api/agent/session/dismiss
DEVICE_DISMISS_TIMEOUT_S=10

# Volcengine TOS（/admin/lab 历史照片回填直传）
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_BUCKET=mojing-photo-cat
TOS_REGION=tos-cn-guangzhou
TOS_ENDPOINT=tos-cn-guangzhou.volces.com
LAB_BACKFILL_PROFILE_TIMEOUT_S=120

# ==================== Flowcut — 拆镜模型 ====================

# Flowcut 拆镜模型（可覆盖默认值 gemini-3.1-flash-lite-preview）
FLOWCUT_DECOMPOSE_MODEL=gemini-3.1-flash-lite-preview

# ==================== Embedding & 向量搜索（Flowcut）====================

# Embedding provider:
#   ollama：本地 Ollama bge-m3，默认 1024 维
#   openai：OpenAI-compatible /v1/embeddings API，默认 1536 维
#   ark_multimodal：火山 Ark /api/v3/embeddings/multimodal，默认复用 VOLCENGINE_API_KEY
FLOWCUT_EMBEDDING_PROVIDER=ollama

# Embedding API（FLOWCUT_EMBEDDING_PROVIDER=openai / ark_multimodal 时使用）
# ark_multimodal 可留空 API_KEY 以复用 VOLCENGINE_API_KEY。
FLOWCUT_EMBEDDING_API_KEY=
FLOWCUT_EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/embeddings/multimodal
FLOWCUT_EMBEDDING_MODEL=doubao-embedding-vision-251215
# 留空则按 provider 自动默认：ollama=1024，openai=1536，ark_multimodal=启动期自动探测。
# 换成其它 embedding 模型时，必须填成该模型实际输出维度。
FLOWCUT_EMBEDDING_VECTOR_SIZE=
# 可选：只有 OpenAI-compatible 模型支持 dimensions 参数时才填写，否则留空
FLOWCUT_EMBEDDING_REQUEST_DIMENSIONS=
FLOWCUT_EMBEDDING_TIMEOUT_S=30

# Ollama Embedding（FLOWCUT_EMBEDDING_PROVIDER=ollama 时使用）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-m3

# Qdrant 向量数据库
QDRANT_URL=http://localhost:6333
