# pnpm 设置 — 替代 package.json 中已废弃的 "pnpm" 字段
# https://pnpm.io/settings

# Electron 二进制文件国内镜像（提速核心！）
# electron postinstall 默认从 GitHub Releases 下载，国内极慢 → 走 npmmirror CDN
electron_mirror=https://npmmirror.com/mirrors/electron/

# 允许以下包运行构建脚本（安装后编译 download electron binaries 等）
onlyBuiltDependencies[]=electron
onlyBuiltDependencies[]=electron-winstaller
onlyBuiltDependencies[]=esbuild
